YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/videoscout

# TikTok search (TrendDiscovery gate + agent scoring)
# Get msToken: tiktok.com → DevTools → Application → Cookies → msToken
TIKTOK_MS_TOKEN=your_ms_token_here
# Optional pool (comma-separated) and/or one-token-per-line file
# TIKTOK_MS_TOKENS=token_a,token_b
# TIKTOK_MS_TOKEN_FILE=/path/to/ms_tokens.txt
# Optional proxy pool for Playwright (http://user:pass@host:port or socks5://host:port)
# TIKTOK_PROXY=http://127.0.0.1:8080
# TIKTOK_PROXIES=http://127.0.0.1:8080,socks5://127.0.0.1:1080
# Anti-bot defaults: visible webkit browser, 3 retries per keyword
# TIKTOK_BROWSER=webkit
# TIKTOK_HEADLESS=false
# TIKTOK_REGION=VN
# TIKTOK_SEARCH_TIMEOUT_SECONDS=30
# TIKTOK_SEARCH_WARM_SLEEP=3
# TIKTOK_SESSION_SLEEP_AFTER=3
# TIKTOK_RETRY_SLEEP_SECONDS=2
# TIKTOK_NUM_SESSIONS=3
# Human-like pacing between keyword searches (discovery batch)
# TIKTOK_SEARCH_PACING=true
# TIKTOK_SEARCH_INTERVAL_MIN_SECONDS=8
# TIKTOK_SEARCH_INTERVAL_MAX_SECONDS=18
# TIKTOK_SEARCH_TYPING_SECONDS_PER_CHAR=0.06
# TIKTOK_SEARCH_INITIAL_DELAY_MIN_SECONDS=1.5
# TIKTOK_SEARCH_INITIAL_DELAY_MAX_SECONDS=4
# TIKTOK_SEARCH_POST_DWELL_MIN_SECONDS=2
# TIKTOK_SEARCH_POST_DWELL_MAX_SECONDS=5
# TIKTOK_SEARCH_FAIL_DWELL_MIN_SECONDS=3
# TIKTOK_SEARCH_FAIL_DWELL_MAX_SECONDS=6

# Discovery jobs stuck in started/running are auto-failed after this many minutes (default 30)
# DISCOVERY_JOB_STALE_MINUTES=30

# LLM HTTP timeout for batch keyword scoring (default 120 seconds)
# LLM_REQUEST_TIMEOUT_SECONDS=120

# Discovery search-sample enrichment + validation (ADR 0014 / US-065)
# TOP_N_VALIDATION=15
# DISCOVERY_VALIDATION_ENABLED=true

# yt-dlp (bulk video download) — requires Node.js on PATH for YouTube JS challenges
# YTDLP_JS_RUNTIMES=node
# YTDLP_SOCKET_TIMEOUT=60
